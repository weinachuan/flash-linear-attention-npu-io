# 复制为环境变量后启动本地后端：python backend/app.py

# SSH 到 NPU 主机执行（推荐）
PERF_RUN_MODE=ssh
PERF_SSH_HOST=your-npu-host
PERF_SSH_USER=your-user
PERF_REMOTE_WORKDIR=/data/flash-linear-attention-npu
PERF_REMOTE_SCRIPT=examples/flash_gated_delta_rule.py
PERF_NPU_DEVICE=2
PERF_PROF_OUTPUT=./prof_gdr
PERF_OP_OUTPUT=./prof_op
PERF_SOC_VERSION=Ascend910B

# 若 IO 后端直接跑在 NPU 主机上：
# PERF_RUN_MODE=local
# PERF_LOCAL_SCRIPT=ref/flash_gated_delta_rule.py

# 仅打印命令、不实际执行：
# PERF_RUN_DRY_RUN=1

# 采集模式说明（看板触发时选择，不可并行）：
# - msprof        → PROF_*     → data/prof_gdr  → import_prof_gdr.py
# - msprof op     → OPPROF_*   → data/prof_op   → import_msprof_op.py
# - msprof op sim → OPPROF_*   → data/prof_op   → import_msprof_op.py
