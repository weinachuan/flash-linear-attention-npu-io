# 复制为环境变量后启动本地后端：python backend/app.py
# 示例：SSH 到 722 NPU 主机执行 msprof
PERF_RUN_MODE=ssh
PERF_SSH_HOST=your-npu-host
PERF_SSH_USER=your-user
# PERF_SSH_PORT=22
# PERF_SSH_IDENTITY_FILE=C:/Users/you/.ssh/id_rsa
PERF_REMOTE_WORKDIR=/data/flash-linear-attention-npu
PERF_REMOTE_SCRIPT=examples/flash_gated_delta_rule.py
PERF_NPU_DEVICE=2
PERF_PROF_OUTPUT=./prof_gdr

# 若 IO 后端直接跑在 NPU 主机上，可改为：
# PERF_RUN_MODE=local
# PERF_LOCAL_SCRIPT=ref/flash_gated_delta_rule.py

# 仅打印命令、不实际执行：
# PERF_RUN_DRY_RUN=1
